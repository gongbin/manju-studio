{
  "name": "manju-studio-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "漫剧工坊 ManjuStudio — Pages(SPA) + Workers + D1 + R2 + KV + Queues. Design ported from ../demo-ui.",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "typecheck:worker": "tsc -p worker/tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply manju-db --local",
    "db:migrate": "wrangler d1 migrations apply manju-db --remote",
    "seed:local": "wrangler dev --test-scheduled & sleep 3 && curl -s -X POST localhost:8787/api/_seed -H \"x-seed-key: dev\"",
    "cf:prepare": "node ./scripts/prepare-cloudflare-build.mjs",
    "cf:build": "npm run cf:prepare && npm run build",
    "cf:deploy:builds": "npm run cf:build && wrangler deploy",
    "deploy": "npm run build && wrangler deploy",
    "cf:provision": "bash ./deploy.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-router": "^1.95.1",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.20",
    "lucide-react": "^0.544.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "drizzle-kit": "^0.30.2",
    "typescript": "~5.7.3",
    "vite": "^6.3.5",
    "wrangler": "^4.98.0"
  }
}
